<!--
  These lines go into android/app/src/main/AndroidManifest.xml. This file is
  inserted automatically by build.yml (sed -i '/<manifest /r manifest-permissions.xml')
  right after the <manifest ...> opening tag — so ONLY put tags here that are
  valid direct children of <manifest> itself: <uses-permission> and
  <uses-feature>. Do NOT put a <service> tag here — it needs to be inside
  <application>, and this file lands outside it. The build.yml workflow
  already handles the background-geolocation <service> tag itself (see the
  "Keep tracking service alive..." step, which merges tools:node="merge"
  onto the service the plugin's own AAR manifest declares).
-->

<!-- Foreground and background location. Android 10+ treats
     ACCESS_BACKGROUND_LOCATION as a SEPARATE permission from
     ACCESS_FINE_LOCATION. The OS shows it as its own dialog, and on
     Android 11+ it can usually only be granted via Settings, Location,
     Allow all the time, rather than the normal in-app popup. -->
<uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
<uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
<uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

<!-- Required for the persistent "WorkPay is tracking your location" notification
     Android mandates for any app running a foreground service. -->
<uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
<uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />

<!-- Keeps the device's location provider awake while the foreground service runs. -->
<uses-permission android:name="android.permission.WAKE_LOCK" />

<!-- Live in-app camera preview for worker punch-in/punch-out photos
     (WebView getUserMedia). Capacitor's WebView auto-handles the runtime
     permission prompt when this is declared — no extra plugin needed. -->
<uses-permission android:name="android.permission.CAMERA" />

<!-- required="false" so the app still installs on devices/tablets with no
     camera — punch-in falls back to the gallery file picker in that case. -->
<uses-feature android:name="android.hardware.camera" android:required="false" />
